# Logging (silent, fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
WHAILEYS_LOG_LEVEL=error

# Database
DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=5432
DB_NAME=whaticket
DB_USER=postgres
DB_PASS=

# JWT Secrets
# Generate strong random values, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changeme-generate-a-strong-secret
JWT_REFRESH_SECRET=changeme-generate-a-different-strong-secret

# Backend URL
BACKEND_URL=http://localhost:8080

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Proxy
PROXY_PORT=8080

# Redis
IO_REDIS_SERVER=127.0.0.1
IO_REDIS_PASSWORD=
IO_REDIS_PORT=6379
IO_REDIS_DB_SESSION=2
